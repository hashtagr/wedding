# Скопируйте в .env и подставьте своё значение.
# Файл .env не попадает в git.
#
# URL веб-приложения Google Apps Script (Развернуть → Веб-приложение, заканчивается на /exec).
# Префикс VITE_ обязателен, чтобы переменная попала в клиентский код.
VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/XXXXXXXX/exec
